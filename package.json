{
  "version": "1.0.0",
  "keywords": [
    "strapi",
    "plugin",
    "seo",
    "ai",
    "openai",
    "anthropic",
    "metadata"
  ],
  "type": "commonjs",
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "types": "./dist/admin/src/index.d.ts",
      "source": "./admin/src/index.ts",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "types": "./dist/server/src/index.d.ts",
      "source": "./server/src/index.ts",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test:ts:front": "run -T tsc -p admin/tsconfig.json",
    "test:ts:back": "run -T tsc -p server/tsconfig.json"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.57.0",
    "openai": "^4.104.0"
  },
  "devDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/strapi": "^5.38.0",
    "@strapi/typescript-utils": "^5.38.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.11",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@strapi/design-system": "^2.0.0-rc.30",
    "@strapi/icons": "^2.0.0-rc.30",
    "@strapi/sdk-plugin": "^5.0.0 || ^6.0.0",
    "@strapi/strapi": "^5.0.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-intl": "^6.0.0",
    "react-router-dom": "^6.0.0",
    "styled-components": "^6.0.0"
  },
  "strapi": {
    "kind": "plugin",
    "name": "strapi-plugin-seo-ai",
    "displayName": "SEO AI",
    "description": "Multi-provider AI-powered SEO metadata & JSON-LD generation (OpenAI Compatible + Anthropic)"
  },
  "name": "strapi-plugin-seo-ai",
  "description": "Multi-provider AI-powered SEO metadata & JSON-LD generation (OpenAI Compatible + Anthropic)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wuzongwen/strapi-plugin-seo-ai.git"
  },
  "bugs": {
    "url": "https://github.com/wuzongwen/strapi-plugin-seo-ai/issues"
  },
  "homepage": "https://github.com/wuzongwen/strapi-plugin-seo-ai#readme",
  "author": ""
}
